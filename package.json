{
	"name": "boilerplate",
	"version": "0.1.0",
	"description": "Example block scaffolded with Create Block tool.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest",
		"format": "wp-scripts format && stylelint 'src/**/*.scss' --fix",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest",
		"prepare": "husky"
	},
	"prettier": "@wordpress/prettier-config",
	"stylelint": {
		"extends": "@wordpress/stylelint-config/scss",
		"rules": {
			"rule-empty-line-before": null
		}
	},
	"lint-staged": {
		"*.{js,jsx}": [
			"wp-scripts lint-js"
		],
		"*.scss": [
			"wp-scripts lint-style"
		]
	},
	"devDependencies": {
		"@wordpress/eslint-plugin": "^24.5.0",
		"@wordpress/prettier-config": "^4.43.0",
		"@wordpress/scripts": "^31.8.0",
		"@wordpress/stylelint-config": "^23.35.0",
		"eslint-config-prettier": "^10.1.8",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"lodash": "^4.18.1",
		"prettier": "^3.7.4",
		"stylelint": "^16.26.1"
	},
	"dependencies": {
		"@wordpress/block-editor": "^15.16.0",
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/components": "^32.5.0",
		"@wordpress/i18n": "^6.16.0",
		"classnames": "^2.5.1"
	}
}
