{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wpblocks/text-box",
  "version": "0.1.0",
  "title": "Text Box",
  "category": "text",
  "description": "A simple text box block.",
  "keywords": [
    "text",
    "box",
    "paragraph"
  ],
  "example": {},
  "supports": {
    "html": false,
    "color": {
      "text": true,
      "background": true,
      "gradients": true
    },
    "spacing": {
      "padding": true
    }
  },
  "textdomain": "text-box",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "attributes": {
    "content": {
      "type": "string",
      "source": "html",
      "selector": "p"
    },
    "alignment": {
      "type": "string",
      "default": "left"
    },
    "backgroundColor": {
      "type": "string"
    },
    "textColor": {
      "type": "string"
    },
    "style": {
      "type": "object",
      "default": {
        "color": {
          "background": "#f03c15"
        },
        "spacing": {
          "padding": {
            "top": "20px",
            "right": "20px",
            "bottom": "20px",
            "left": "20px"
          }
        }
      }
    }
  }
}